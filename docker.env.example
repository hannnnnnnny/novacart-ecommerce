# NovaCart Docker Compose environment example.
# Copy this file to .env before running docker compose if you want to override the local defaults.
# These values are for local preview only and must not be reused in production.

MYSQL_DATABASE=novacart
MYSQL_USER=novacart_user
MYSQL_PASSWORD=novacart_password
MYSQL_ROOT_PASSWORD=novacart_root_password
MYSQL_PORT=3306

BACKEND_PORT=8080
JWT_SECRET=replace-with-a-long-random-secret-for-local-docker-only
JWT_EXPIRATION_MINUTES=120

FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8080/api
